{
	"name": "django-moo",
	"dockerComposeFile": [
		"../compose.yml",
		"../compose.override.yml",
		"../compose.devcontainer.yml"
	],
	"mounts": [
		"source=${localEnv:HOME}/.claude,target=/usr/app/.claude,type=bind,consistency=cached"
	],
	"containerEnv": {
		"SHELL": "/usr/bin/bash"
	},
	"remoteUser": "www-data",
	"service": "celery",
	"workspaceFolder": "/usr/app/src",
	"shutdownAction": "stopCompose",
	"overrideCommand": true,
	"otherPortsAttributes": { "onAutoForward" : "ignore" },
	"customizations": {
		"vscode": {
			"settings": {
				"python.defaultInterpreterPath": "/usr/app/bin/python",
				"python.testing.unittestEnabled": true,
				"python.testing.pytestEnabled": true,
				"python.testing.pytestArgs": ["--ds=moo.settings.test"],
				// Language-specific editor settings for Python files.
				"[python]": {
					"editor.defaultFormatter": "charliermarsh.ruff",
					"editor.formatOnSave": true,
					"editor.codeActionsOnSave": {
						"source.organizeImports": "explicit"
					}
				}
			},
			"extensions": [
				"ms-python.debugpy",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"charliermarsh.ruff",
				"DavidAnson.vscode-markdownlint"
				// Add additional extensions here:
			]
		}
	}
}
